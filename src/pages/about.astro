---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="max-w-3xl mx-auto">
    <header class="mb-12 text-center" transition:animate="fade">
      <h1 class="text-5xl mb-4">About</h1>
    </header>
    
    <div class="prose prose-lg dark:prose-invert max-w-none" transition:animate="fade">
      <p>Hi, I'm Q.</p>
      
      <p>
        This is a small personal blog for notes, reviews, and things I'm thinking about.
      </p>
      
      <p>
        I may write in English or Chinese. Topics might include AI, games, books, films, travel, work, 
        or anything else I feel like saving somewhere nicer than a random note app.
      </p>
      
      <p>That's pretty much it.</p>
    </div>
  </div>
</BaseLayout>
